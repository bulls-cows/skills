{
  "name": "open-skills",
  "version": "1.0.0",
  "description": "本仓库维护了一些实用的规则和AI技能。",
  "main": "README.md",
  "type": "module",
  "scripts": {
    "lint": "node --run check:skill && node --run lint:markdown && node --run check:type && node --run sync:marketplace",
    "check:skill": "node ./build/check-skill.mts",
    "lint:markdown": "markdownlint \"**/*.md\" --fix --ignore node_modules",
    "check:type": "tsc --noEmit",
    "sync:marketplace": "node ./build/sync-marketplace.mts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bulls-cows/skills.git"
  },
  "keywords": [
    "open-skills",
    "ai",
    "skills",
    "bulls-cows",
    "bulls-cows/skills"
  ],
  "author": "bulls-cows",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/bulls-cows/skills/issues"
  },
  "homepage": "https://github.com/bulls-cows/skills#readme",
  "devDependencies": {
    "@types/node": "22.19.15",
    "markdownlint-cli": "0.48.0",
    "typescript": "5.9.3"
  }
}
